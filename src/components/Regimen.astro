---
import { products, AMAZON_DISCLOSURE } from '../data/products';
import Disclosure from './Disclosure.astro';

// Per-product usage details, keyed to products.ts order.
const usage = [
  {
    frequency: '1 night a week',
    summary:
      'Use as a short-contact face treatment instead of your normal cleanse. Not every day.',
    steps: [
      'Wet your face with lukewarm water.',
      'Work a small amount into a light lather over the affected areas.',
      'Leave it on for three to five minutes. The contact time is what lets it work.',
      'Rinse well, pat dry, and moisturize.',
    ],
    note: `Gentle, well-tolerated, and safe long-term at this rhythm. I've used it for years. It is not "harsh," despite what some marketing implies.`,
  },
  {
    frequency: 'Nightly',
    summary:
      'Once a day, ideally at night, lukewarm water. Mornings, a plain water rinse is enough.',
    steps: null,
    note: 'On antifungal nights it gets replaced, not stacked. It only needs to clean without irritating. It does not need to be expensive.',
  },
  {
    frequency: 'Morning + night',
    summary: 'After cleansing, every time. Add sunscreen in the morning if you’ll be outside.',
    steps: null,
    note: 'Ceramides are the exact lipids a seb-derm barrier is short on, and a moisturizer stays on for hours, so it has time to do real repair. This is what raises your threshold.',
  },
];

const week = [
  { when: 'Most nights', what: 'gentle cleanse → moisturizer' },
  { when: '1 night a week', what: 'antifungal (3–5 min) → moisturizer' },
  { when: 'Every morning', what: 'water rinse → moisturizer → sunscreen if needed' },
];
---

<section class="panel section--band" id="regimen">
  <div class="container">
    <div class="prose">
      <span class="eyebrow">My routine</span>
      <h2>Three products. About forty dollars.</h2>
      <p>This is exactly what I use, and exactly how I use it.</p>
    </div>

    <p class="amazon-line">{AMAZON_DISCLOSURE}</p>

    <!-- One card, three products, subtle dividers between them -->
    <div class="card">
      {products.map((p, i) => (
        <article class="product">
          <div class="product__image">
            <img src={p.image} alt={p.imageAlt} width="210" loading="lazy" />
          </div>
          <span class="product__role">{p.role} · {usage[i].frequency}</span>
          <h3 class="product__name">{p.name}</h3>
          <p class="product__blurb">{p.blurb}</p>
          <p class="product__price">{p.price}</p>
          <a href={p.link} class="btn btn--buy" target="_blank" rel="nofollow sponsored noopener noreferrer">
            Get it on Amazon
          </a>
        </article>
      ))}
    </div>

    <!-- How-to expanders, one per product, just below the card -->
    <div class="hows">
      {products.map((p, i) => (
        <details class="how">
          <summary>How to use {p.name.split(' (')[0]}</summary>
          <div class="how__body">
            <p>{usage[i].summary}</p>
            {usage[i].steps && (
              <ol>
                {usage[i].steps.map((s) => <li>{s}</li>)}
              </ol>
            )}
            <p class="how__note">{usage[i].note}</p>
          </div>
        </details>
      ))}
    </div>

    <div class="week">
      <h3>My week, at a glance</h3>
      <dl>
        {week.map((w) => (
          <div class="week__row">
            <dt>{w.when}</dt>
            <dd>{w.what}</dd>
          </div>
        ))}
      </dl>
      <p class="week__note">
        That's the whole thing. It cost me roughly the price of one bottle of
        the premium stuff, and it lasts me months. And honestly, after the first
        few months, I only use the Nizoral once a month and moisturizer at night.
      </p>
    </div>

    <Disclosure />
  </div>
</section>

<style>
  .amazon-line {
    font-size: var(--text-xs);
    color: var(--color-ink-soft);
    margin: 1.5rem 0 0.75rem;
  }

  .card {
    background: var(--color-surface);
    border-radius: var(--radius-lg);
    box-shadow: var(--shadow-soft);
    display: grid;
    margin-bottom: 2.5rem;
  }
  .product {
    padding: 2rem 1.75rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    /* horizontal divider when stacked (mobile) */
    border-top: 1px solid var(--color-line);
  }
  .product:first-child { border-top: none; }

  .product__image {
    align-self: center;
    height: 150px;
    display: flex;
    align-items: flex-end;
    margin-bottom: 1.25rem;
  }
  .product__image img {
    max-height: 150px;
    width: auto;
  }
  .product__role {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    text-transform: uppercase;
    letter-spacing: 0.04em;
    color: var(--color-pop-deep);
  }
  .product__name {
    font-size: var(--text-lg);
    margin: 0.35rem 0 0.4rem;
  }
  .product__blurb {
    color: var(--color-ink-soft);
    font-size: var(--text-sm);
    flex-grow: 1;
  }
  .product__price {
    font-weight: 700;
    margin-bottom: 0.9rem;
  }
  .hows {
    display: grid;
    row-gap: 0.85rem;
    margin: -1.5rem 0 2.5rem;
  }
  .how {
    min-width: 0;
  }
  .how summary {
    cursor: pointer;
    list-style: none;
    font-family: var(--font-display);
    font-weight: 700;
    font-size: var(--text-sm);
    color: var(--color-pop-deep);
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 0.85rem;
    min-height: 3.5rem;
    padding: 0.9rem 1.1rem;
    border: 1px solid var(--color-line);
    border-radius: 999px;
    background: color-mix(in srgb, var(--color-surface) 72%, transparent);
  }
  .how summary::-webkit-details-marker { display: none; }
  .how summary::after {
    content: '+';
    flex: 0 0 auto;
    font-size: 1.2em;
    transition: transform 0.2s ease;
  }
  .how[open] summary::after { transform: rotate(45deg); }
  .how__body {
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
    margin-top: 0.85rem;
    padding: 0 1.1rem;
  }
  .how__body ol { padding-left: 1.2rem; margin: 0.5rem 0; }
  .how__body li { margin-bottom: 0.3rem; }
  .how__note {
    background: var(--color-bg);
    border-left: 3px solid var(--color-pop);
    border-radius: 0 var(--radius) var(--radius) 0;
    padding: 0.6rem 0.9rem;
    margin-bottom: 0;
  }

  .week {
    max-width: var(--measure);
    margin-bottom: 2.5rem;
  }
  .week h3 { font-size: var(--text-lg); }
  .week dl { margin: 0; }
  .week__row {
    display: grid;
    grid-template-columns: minmax(9rem, auto) 1fr;
    gap: 1rem;
    padding-block: 0.6rem;
    border-bottom: 1px solid var(--color-line);
  }
  .week__row dt { font-weight: 700; font-size: var(--text-sm); }
  .week__row dd { margin: 0; font-size: var(--text-sm); color: var(--color-ink-soft); }
  .week__note {
    margin-top: 1rem;
    font-size: var(--text-sm);
    color: var(--color-ink-soft);
  }

  @media (min-width: 760px) {
    .card { grid-template-columns: repeat(3, 1fr); }
    .hows { grid-template-columns: repeat(3, 1fr); }
    .how summary {
      width: calc(100% - 0.85rem);
      margin-inline: auto;
    }
    .product {
      border-top: none;
      /* subtle vertical divider between columns */
      border-left: 1px solid var(--color-line);
    }
    .product:first-child { border-left: none; }
  }
</style>
