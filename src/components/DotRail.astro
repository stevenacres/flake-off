---
// Side index: one dot per section, tracks scroll position, click to jump.
// The only client JS on the site (~20 lines, IntersectionObserver).
const sections = [
  { id: 'top', label: 'Start' },
  { id: 'problem', label: 'The problem' },
  { id: 'science', label: 'The science' },
  { id: 'why-it-fails', label: 'Why the hype fails' },
  { id: 'regimen', label: 'The routine' },
  { id: 'faq', label: 'FAQ' },
];
---

<nav class="dotrail" aria-label="Page sections">
  {sections.map((s) => (
    <a href={`#${s.id}`} data-dot={s.id} class="dotrail__dot">
      <span class="dotrail__label">{s.label}</span>
      <span class="dotrail__circle" aria-hidden="true"></span>
    </a>
  ))}
</nav>

<script>
  const dots = document.querySelectorAll('[data-dot]');
  const observer = new IntersectionObserver(
    (entries) => {
      for (const entry of entries) {
        if (!entry.isIntersecting) continue;
        dots.forEach((d) =>
          d.classList.toggle(
            'is-active',
            d.getAttribute('data-dot') === entry.target.id
          )
        );
      }
    },
    // section counts as "current" when it crosses the middle of the viewport
    { rootMargin: '-45% 0px -45% 0px' }
  );
  dots.forEach((d) => {
    const target = document.getElementById(d.getAttribute('data-dot'));
    if (target) observer.observe(target);
  });
</script>

<style>
  .dotrail {
    position: fixed;
    right: 1.25rem;
    top: 50%;
    transform: translateY(-50%);
    z-index: 40;
    display: none;
    flex-direction: column;
    gap: 0.9rem;
  }
  @media (min-width: 860px) {
    .dotrail { display: flex; }
  }
  .dotrail__dot {
    display: flex;
    align-items: center;
    justify-content: flex-end;
    gap: 0.6rem;
    text-decoration: none;
  }
  .dotrail__circle {
    width: 10px;
    height: 10px;
    border-radius: 50%;
    background: transparent;
    box-shadow: inset 0 0 0 2px var(--color-ink-soft);
    transition: background-color 0.2s ease, transform 0.2s ease,
      box-shadow 0.2s ease;
    flex-shrink: 0;
  }
  .dotrail__label {
    font-family: var(--font-mono);
    font-size: var(--text-xs);
    font-weight: 400;
    color: var(--color-ink);
    background: var(--color-surface);
    padding: 0.25rem 0.7rem;
    border-radius: 999px;
    box-shadow: var(--shadow-soft);
    opacity: 0;
    transform: translateX(6px);
    transition: opacity 0.15s ease, transform 0.15s ease;
    pointer-events: none;
    white-space: nowrap;
  }
  .dotrail__dot:hover .dotrail__label,
  .dotrail__dot:focus-visible .dotrail__label,
  .dotrail__dot.is-active .dotrail__label {
    opacity: 1;
    transform: translateX(0);
  }
  .dotrail__dot.is-active .dotrail__label {
    color: var(--color-pop-deep);
  }
  .dotrail__dot:hover .dotrail__circle {
    box-shadow: inset 0 0 0 2px var(--color-pop-deep);
  }
  .dotrail__dot.is-active .dotrail__circle {
    background: var(--color-pop);
    box-shadow: inset 0 0 0 2px var(--color-pop);
    transform: scale(1.25);
  }
</style>
